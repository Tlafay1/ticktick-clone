{
  "name": "ticktick-clone-desktop",
  "version": "1.0.0",
  "description": "TickTick Clone – client Windows/Linux (Electron)",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "test": "vitest run"
  },
  "dependencies": {
    "electron-store": "^10.0.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.0.0",
    "vitest": "^2.0.0"
  },
  "build": {
    "appId": "com.ticktick.clone",
    "productName": "TickTick Clone",
    "directories": { "output": "dist-electron" },
    "files": ["main.js", "preload.js", "assets/**"],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": "AppImage"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
