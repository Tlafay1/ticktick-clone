{
  "name": "ticktick-clone-desktop",
  "version": "1.0.0",
  "description": "TickTick Clone – client Windows/Linux (Electron)",
  "author": "Tlafay1",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "test": "vitest run"
  },
  "dependencies": {
    "electron-store": "^10.0.0",
    "electron-updater": "^6.3.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.0.0",
    "vitest": "^2.0.0"
  },
  "build": {
    "appId": "com.ticktick.clone",
    "productName": "TickTick Clone",
    "publish": {
      "provider": "github",
      "owner": "Tlafay1",
      "repo": "ticktick-clone",
      "releaseType": "release"
    },
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "main.js",
      "preload.js",
      "serve-dist.js",
      "assets/**"
    ],
    "extraResources": [
      {
        "from": "../web/dist",
        "to": "web-dist"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": "AppImage"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
