# Variables d'environnement de production (clone TickTick).
# Copier en .env et renseigner. Utilisé par docker-compose.prod.yml / Dokploy.

# --- Django ---
# Générer : python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=0
# Hôte(s) servant l'API (CSV). Ex : tasks.exemple.com
DJANGO_ALLOWED_HOSTS=tasks.exemple.com
# Origines autorisées pour le front (CSV, avec schéma). Ex : https://tasks.exemple.com
DJANGO_CORS_ALLOWED_ORIGINS=https://tasks.exemple.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://tasks.exemple.com
# Mettre à 1 pour forcer la redirection HTTPS si Traefik ne le fait pas déjà.
DJANGO_SECURE_SSL_REDIRECT=0

# --- PostgreSQL ---
POSTGRES_DB=ticktick
POSTGRES_USER=ticktick
POSTGRES_PASSWORD=change-me-too

# --- Redis (broker Celery + Channels) ---
# En compose, l'hôte est le nom de service « redis » (déjà câblé).
REDIS_HOST=redis
REDIS_PORT=6379

# --- Web Push (VAPID) ---
# Générer une paire : voir docs/deploiement.md (« vapid --gen » ou py-vapid).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_ADMIN_EMAIL=admin@exemple.com

# --- Front (port hôte exposé par le conteneur nginx) ---
WEB_PORT=8080
